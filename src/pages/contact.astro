---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<section class="py-20 bg-primary text-background">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-serif font-bold mb-6">Contact</h1>
			<p class="text-xl opacity-90 max-w-2xl mx-auto">Vragen, suggesties of interesse om mee te werken? We horen het graag!</p>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="grid md:grid-cols-2 gap-16 max-w-6xl mx-auto">
				<div>
					<h2 class="text-3xl font-serif font-bold mb-8 text-primary">Stuur ons een bericht</h2>
					<form class="space-y-6">
						<div>
							<label for="name" class="block text-sm font-bold mb-2">Naam</label>
							<input type="text" id="name" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all" placeholder="Jouw naam" />
						</div>
						<div>
							<label for="email" class="block text-sm font-bold mb-2">Email</label>
							<input type="email" id="email" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all" placeholder="jouw@email.be" />
						</div>
						<div>
							<label for="subject" class="block text-sm font-bold mb-2">Onderwerp</label>
							<select id="subject" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all">
								<option>Algemene vraag</option>
								<option>Tickets & Reserveringen</option>
								<option>Lid worden</option>
								<option>Sponsoring</option>
							</select>
						</div>
						<div>
							<label for="message" class="block text-sm font-bold mb-2">Bericht</label>
							<textarea id="message" rows="5" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-all" placeholder="Hoe kunnen we je helpen?"></textarea>
						</div>
						<button type="submit" class="btn-primary w-full text-lg">Verstuur bericht</button>
					</form>
				</div>

				<div>
					<h2 class="text-3xl font-serif font-bold mb-8 text-primary">Onze Gegevens</h2>
					<div class="space-y-8">
						<div class="flex gap-6">
							<div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center text-accent shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
							</div>
							<div>
								<h3 class="font-bold text-xl mb-2">Locatie</h3>
								<p class="text-gray-600">Dorpsstraat 1<br />9000 Gent, België</p>
							</div>
						</div>

						<div class="flex gap-6">
							<div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center text-accent shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
								</svg>
							</div>
							<div>
								<h3 class="font-bold text-xl mb-2">Email</h3>
								<p class="text-gray-600">info@toneeldevalk.be<br />reservaties@toneeldevalk.be</p>
							</div>
						</div>

						<div class="flex gap-6">
							<div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center text-accent shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
							</div>
							<div>
								<h3 class="font-bold text-xl mb-2">Repetitietijden</h3>
								<p class="text-gray-600">Elke dinsdag en donderdag<br />20:00 - 22:30</p>
							</div>
						</div>
					</div>

					<div class="mt-12 rounded-3xl overflow-hidden shadow-lg h-64 bg-gray-200">
						<!-- Placeholder for Map -->
						<div class="w-full h-full flex items-center justify-center text-gray-400 italic">
							Google Maps kaart placeholder
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
