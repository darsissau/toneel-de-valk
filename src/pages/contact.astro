---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<section class="py-32 bg-primary-text text-bg-ivory">
		<div class="container-custom text-center">
			<h1 class="text-5xl md:text-8xl font-serif mb-8 tracking-tighter">Contact</h1>
			<p class="text-accent-gold uppercase tracking-[0.4em] text-xs font-bold">Voor reserveringen en vragen</p>
		</div>
	</section>

	<section class="py-24">
		<div class="container-custom">
			<div class="grid md:grid-cols-2 gap-24 max-w-5xl mx-auto">
				<div>
					<h2 class="text-3xl md:text-4xl font-serif mb-12 tracking-tight">Stuur ons een bericht</h2>
					<form class="space-y-10">
						<div class="relative group">
							<input type="text" id="name" class="w-full bg-transparent border-b border-ui-border py-4 focus:border-accent-gold outline-none transition-colors peer placeholder-transparent" placeholder="Naam" />
							<label for="name" class="absolute left-0 top-4 text-xs uppercase tracking-widest font-bold text-primary-text/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-primary-text/20 peer-placeholder-shown:top-4 peer-focus:top-[-12px] peer-focus:text-xs peer-focus:text-accent-gold">Naam</label>
						</div>
						<div class="relative group">
							<input type="email" id="email" class="w-full bg-transparent border-b border-ui-border py-4 focus:border-accent-gold outline-none transition-colors peer placeholder-transparent" placeholder="Email" />
							<label for="email" class="absolute left-0 top-4 text-xs uppercase tracking-widest font-bold text-primary-text/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-primary-text/20 peer-placeholder-shown:top-4 peer-focus:top-[-12px] peer-focus:text-xs peer-focus:text-accent-gold">Email</label>
						</div>
						<div class="relative group">
							<textarea id="message" rows="4" class="w-full bg-transparent border-b border-ui-border py-4 focus:border-accent-gold outline-none transition-colors peer placeholder-transparent resize-none" placeholder="Bericht"></textarea>
							<label for="message" class="absolute left-0 top-4 text-xs uppercase tracking-widest font-bold text-primary-text/40 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-primary-text/20 peer-placeholder-shown:top-4 peer-focus:top-[-12px] peer-focus:text-xs peer-focus:text-accent-gold">Uw bericht</label>
						</div>
						<button type="submit" class="btn-theatre-primary w-full py-6 tracking-[0.3em]">Verzenden</button>
					</form>
				</div>

				<div class="space-y-16">
					<div>
						<h2 class="text-sm uppercase tracking-[0.3em] font-bold text-accent-gold mb-10">Informatie</h2>
						<div class="space-y-12">
							<div class="flex flex-col">
								<span class="text-[10px] uppercase tracking-widest text-primary-text/40 mb-2">Email</span>
								<a href="mailto:info@toneeldevalk.be" class="text-xl font-serif hover:text-accent-burgundy transition-colors">info@toneeldevalk.be</a>
							</div>
							<div class="flex flex-col">
								<span class="text-[10px] uppercase tracking-widest text-primary-text/40 mb-2">Locatie</span>
								<p class="text-xl font-serif">De Valk Studio, Dorpsstraat 1<br />9000 Gent, België</p>
							</div>
							<div class="flex flex-col">
								<span class="text-[10px] uppercase tracking-widest text-primary-text/40 mb-2">Social</span>
								<div class="flex gap-8 mt-2">
									<a href="#" class="text-xs uppercase tracking-widest font-bold border-b border-accent-gold hover:text-accent-burgundy transition-colors">Instagram</a>
									<a href="#" class="text-xs uppercase tracking-widest font-bold border-b border-accent-gold hover:text-accent-burgundy transition-colors">Facebook</a>
								</div>
							</div>
						</div>
					</div>

					<div class="aspect-square w-full rounded-lg overflow-hidden border border-ui-border grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700">
						<!-- Map Placeholder -->
						<div class="w-full h-full bg-primary-text/10 flex items-center justify-center text-[10px] uppercase tracking-[0.5em] text-primary-text/40">
							Gent Map
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
