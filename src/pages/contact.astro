---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" transparentNav={true}>
	<!-- Hero Section: Clean & Bold -->
	<section class="relative h-[60vh] flex items-center bg-primary-text overflow-hidden">
		<div class="absolute inset-0 z-0">
			<!-- Pure image, no heavy digital gradient -->
			<!-- <img 
				src="https://images.unsplash.com/photo-1503095396549-807a8bc36674?q=80&w=2400&auto=format&fit=crop" 
				class="w-full h-full object-cover grayscale opacity-40"
				alt="Theatre backdrop"
			/> -->
			<!-- Single solid overlay for text contrast if needed -->
			<div class="absolute inset-0 bg-primary-text/20"></div>
		</div>
		
		<div class="container-custom relative z-10 w-full">
			<div class="fade-in">
				<span class="text-accent-gold uppercase tracking-[0.6em] text-[10px] font-bold mb-6 block">RESERVATIES & VRAGEN</span>
				<h1 class="text-7xl md:text-9xl text-bg-ivory leading-none tracking-tighter uppercase">
					CON<span class="italic font-normal">TACT</span>
				</h1>
			</div>
		</div>
	</section>

	<!-- Main Content: Stable Two-Column Layout -->
	<section class="py-24 md:py-32 bg-bg-ivory">
		<div class="container-custom">
			<div class="grid lg:grid-cols-12 gap-16 lg:gap-24">
				
				<!-- Form Side -->
				<div class="lg:col-span-7">
					<h2 class="text-3xl md:text-4xl font-serif mb-8 tracking-tight">Laat van u horen.</h2>
					<p class="text-primary-text/60 mb-16 leading-relaxed italic border-l-2 border-accent-gold/20 pl-6">
						"Elke ontmoeting begint met een eerste woord. Wij kijken daarnaar uit."
					</p>
					
					<form class="space-y-12">
						<div class="group border-b border-primary-text/10 focus-within:border-accent-gold transition-colors pb-4">
							<label for="name" class="block text-[10px] uppercase tracking-widest font-bold text-primary-text/30 mb-2">Naam</label>
							<input type="text" id="name" class="w-full bg-transparent py-2 outline-none text-xl font-serif placeholder:text-primary-text/30" placeholder="Naam Voornaam" />
						</div>
						
						<div class="group border-b border-primary-text/10 focus-within:border-accent-gold transition-colors pb-4">
							<label for="email" class="block text-[10px] uppercase tracking-widest font-bold text-primary-text/30 mb-2">Email</label>
							<input type="email" id="email" class="w-full bg-transparent py-2 outline-none text-xl font-serif placeholder:text-primary-text/30" placeholder="uw@email.be" />
						</div>
						
						<div class="group border-b border-primary-text/10 focus-within:border-accent-gold transition-colors pb-4">
							<label for="message" class="block text-[10px] uppercase tracking-widest font-bold text-primary-text/30 mb-2">Bericht</label>
							<textarea id="message" rows="1" class="w-full bg-transparent py-2 outline-none text-xl font-serif placeholder:text-primary-text/30 resize-none" placeholder="Hoe kunnen we u helpen?"></textarea>
						</div>
						
						<div class="pt-8">
							<button type="submit" class="btn-theatre-primary px-16 py-5">
								Verzenden
							</button>
						</div>
					</form>
				</div>

				<!-- Info Side -->
				<aside class="lg:col-span-5 space-y-16">
					<div class="bg-white p-12 border border-primary-text/5 shadow-sm">
						<h3 class="text-accent-gold text-[10px] uppercase tracking-[0.4em] font-bold mb-12">INFORMATIE</h3>
						
						<div class="space-y-12">
							<div>
								<span class="text-[9px] uppercase tracking-widest text-primary-text/30 mb-4 block font-bold">Email</span>
								<a href="mailto:info@toneeldevalk.be" class="text-2xl font-serif hover:text-accent-gold transition-colors block">info@toneeldevalk.be</a>
							</div>

							<div>
								<span class="text-[9px] uppercase tracking-widest text-primary-text/30 mb-4 block font-bold">Vaste Speelplek</span>
								<p class="text-2xl font-serif leading-tight">
									Magdalenazaal<br />
									<span class="text-primary-text/40">Brugge, BE</span>
								</p>
							</div>

							<div>
								<span class="text-[9px] uppercase tracking-widest text-primary-text/30 mb-6 block font-bold">Social Media</span>
								<div class="flex gap-8">
									<a href="#" class="text-[11px] font-bold uppercase tracking-widest border-b border-accent-gold/20 hover:border-accent-gold transition-colors pb-1">Instagram</a>
									<a href="#" class="text-[11px] font-bold uppercase tracking-widest border-b border-accent-gold/20 hover:border-accent-gold transition-colors pb-1">Facebook</a>
								</div>
							</div>
						</div>
					</div>
				</aside>

			</div>
		</div>
	</section>
</Layout>
