---
import Layout from '../../layouts/Layout.astro';

const voorstellingen = Object.values(import.meta.glob('../../../content/voorstellingen/*.md', { eager: true }));
const sortedVoorstellingen = voorstellingen.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date.split('-').reverse().join('-'));
  const dateB = new Date(b.frontmatter.date.split('-').reverse().join('-'));
  return dateA - dateB;
});
---

<Layout title="Voorstellingen">
	<section class="py-32 bg-primary-text text-bg-ivory">
		<div class="container-custom text-center">
			<span class="text-accent-gold uppercase tracking-[0.4em] text-xs font-bold mb-6 block">Seizoen 2026</span>
			<h1 class="text-5xl md:text-8xl font-serif mb-8 tracking-tighter">Programma</h1>
			<div class="w-24 h-px bg-accent-gold mx-auto"></div>
		</div>
	</section>

	<section class="py-24">
		<div class="container-custom">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
				{sortedVoorstellingen.map((item) => (
					<a href={`/voorstellingen/${item.file.split('/').pop().replace('.md', '')}`} class="theatre-card group">
						<div class="aspect-[3/4] overflow-hidden">
							<img src={item.frontmatter.image} alt={item.frontmatter.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" onerror="this.src='https://images.unsplash.com/photo-1507676184212-d03ab07a01bf?q=80&w=1000&auto=format&fit=crop'" />
						</div>
						<div class="p-10">
							<p class="text-accent-gold text-xs font-bold uppercase tracking-[0.2em] mb-4">{item.frontmatter.date}</p>
							<h3 class="text-3xl font-serif mb-6 group-hover:text-accent-burgundy transition-colors tracking-tight leading-tight">{item.frontmatter.title}</h3>
							<p class="text-primary-text/60 text-sm mb-8 line-clamp-3 leading-relaxed">
								{item.rawContent().substring(0, 150)}...
							</p>
							<span class="text-xs uppercase tracking-widest font-bold text-accent-burgundy flex items-center gap-3">
								Bekijk voorstelling <span class="w-8 h-px bg-accent-burgundy group-hover:w-12 transition-all"></span>
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
