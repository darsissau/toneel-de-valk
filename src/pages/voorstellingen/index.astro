---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const voorstellingen = await getCollection('voorstellingen');
const sortedVoorstellingen = voorstellingen.sort((a, b) => {
  const dateA = new Date(a.data.date.split('-').reverse().join('-'));
  const dateB = new Date(b.data.date.split('-').reverse().join('-'));
  return dateA - dateB;
});
---

<Layout title="Voorstellingen">
	<section class="pt-48 pb-32 bg-bg-ivory">
		<div class="container-custom">
			<div class="max-w-3xl">
				<p class="text-accent-gold uppercase tracking-[0.5em] text-[10px] font-bold mb-10">Archief & Toekomst</p>
				<h1 class="text-6xl md:text-8xl mb-12 tracking-tighter leading-[0.85]">Onze<br/><span class="italic font-normal">Voorstellingen</span></h1>
				<div class="w-16 h-1 bg-accent-gold"></div>
			</div>
		</div>
	</section>

	<section class="py-32 bg-white">
		<div class="container-custom">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-32">
				{sortedVoorstellingen.map((item) => (
					<a href={`/voorstellingen/${item.id || item.slug}`} class="theatre-card">
						<div class="theatre-card-image bg-primary-text/5">
							<img 
								src={item.data.image} 
								alt={item.data.title} 
								onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1507676184212-d03ab07a01bf?q=80&w=1000&auto=format&fit=crop';"
							/>
						</div>
						<div class="theatre-card-content">
							<p class="text-accent-gold text-[10px] uppercase tracking-[0.2em] font-bold mb-4">{item.data.date}</p>
							<h2 class="text-3xl mb-6 group-hover:text-accent-gold transition-colors tracking-tight leading-tight">{item.data.title}</h2>
							<p class="text-primary-text/40 text-xs uppercase tracking-widest font-bold flex items-center gap-4">
								Ontdek <span class="w-8 h-px bg-primary-text/10 group-hover:bg-accent-gold group-hover:w-12 transition-all"></span>
							</p>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
