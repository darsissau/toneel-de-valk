---
import Layout from '../../layouts/Layout.astro';

const voorstellingen = Object.values(import.meta.glob('../../../content/voorstellingen/*.md', { eager: true }));
const sortedVoorstellingen = voorstellingen.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date.split('-').reverse().join('-'));
  const dateB = new Date(b.frontmatter.date.split('-').reverse().join('-'));
  return dateA - dateB;
});
---

<Layout title="Voorstellingen">
	<section class="py-20 bg-primary text-background">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-5xl font-serif font-bold mb-6">Onze Voorstellingen</h1>
			<p class="text-xl opacity-90 max-w-2xl mx-auto">Ontdek ons aanbod aan klassieke en moderne theaterstukken.</p>
		</div>
	</section>

	<section class="py-20">
		<div class="container mx-auto px-4">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
				{sortedVoorstellingen.map((item) => (
					<a href={`/voorstellingen/${item.file.split('/').pop().replace('.md', '')}`} class="card group">
						<div class="aspect-[3/4] overflow-hidden">
							<img src={item.frontmatter.image} alt={item.frontmatter.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" onerror="this.src='https://images.unsplash.com/photo-1503095396549-807a8bc36674?q=80&w=1000&auto=format&fit=crop'" />
						</div>
						<div class="p-8">
							<p class="text-accent text-sm font-bold mb-3">{item.frontmatter.date}</p>
							<h3 class="text-2xl font-serif font-bold mb-4 group-hover:text-primary transition-colors">{item.frontmatter.title}</h3>
							<p class="text-gray-600 mb-6 line-clamp-3">
								{item.rawContent().substring(0, 150)}...
							</p>
							<span class="text-primary font-bold inline-flex items-center group-hover:translate-x-2 transition-transform">
								Bekijk details <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
									<path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
								</svg>
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
