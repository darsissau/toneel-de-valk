---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const voorstellingen = Object.values(import.meta.glob('../../../content/voorstellingen/*.md', { eager: true }));
  return voorstellingen.map(post => ({
    params: { slug: post.file.split('/').pop().replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
const { title, date, image, ticket_link } = post.frontmatter;
---

<Layout title={title}>
	<article class="py-20">
		<div class="container mx-auto px-4 max-w-4xl">
			<a href="/voorstellingen" class="text-primary font-bold mb-8 inline-block hover:translate-x-[-8px] transition-transform">
				&larr; Terug naar overzicht
			</a>
			
			<div class="aspect-video rounded-3xl overflow-hidden shadow-2xl mb-12">
				<img src={image} alt={title} class="w-full h-full object-cover" onerror="this.src='https://images.unsplash.com/photo-1507676184212-d03ab07a01bf?q=80&w=1000&auto=format&fit=crop'" />
			</div>

			<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
				<div>
					<div class="inline-block px-4 py-1 bg-accent/20 text-accent font-bold rounded-full text-sm mb-4">
						{date}
					</div>
					<h1 class="text-4xl md:text-6xl font-serif font-bold text-primary">{title}</h1>
				</div>
				{ticket_link && (
					<a href={ticket_link} target="_blank" class="btn-primary text-xl px-10 py-4 shadow-xl">Reserveer Tickets</a>
				)}
			</div>

			<div class="prose prose-lg max-w-none text-gray-700 leading-relaxed first-letter:text-5xl first-letter:font-serif first-letter:font-bold first-letter:text-primary first-letter:mr-3 first-letter:float-left">
				<Content />
			</div>

			<div class="mt-20 p-10 bg-gray-50 rounded-3xl border border-gray-100 text-center">
				<h3 class="text-2xl font-serif font-bold mb-4">Interesse in deze voorstelling?</h3>
				<p class="mb-8 text-gray-600 italic">Vragen over tickets of groepsreserveringen? Neem gerust contact met ons op.</p>
				<a href="/contact" class="btn-secondary">Contacteer ons</a>
			</div>
		</div>
	</article>
</Layout>
