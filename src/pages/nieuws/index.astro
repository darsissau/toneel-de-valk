---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const nieuws = await getCollection('nieuws');
const sortedNieuws = nieuws.sort((a, b) => {
  const dateA = new Date(a.data.date.split('-').reverse().join('-'));
  const dateB = new Date(b.data.date.split('-').reverse().join('-'));
  return dateB - dateA;
});
---

<Layout title="Nieuws">
	<section class="pt-48 pb-32 bg-bg-ivory">
		<div class="container-custom">
			<h1 class="text-7xl md:text-9xl mb-12 tracking-tighter leading-[0.85]">Journal</h1>
			<p class="text-accent-gold uppercase tracking-[0.5em] text-[10px] font-bold">Het laatste uit onze coulissen</p>
		</div>
	</section>

	<section class="py-32 bg-white">
		<div class="container-custom max-w-4xl">
			<div class="space-y-48">
				{sortedNieuws.map((post) => (
					<article class="group">
						<div class="aspect-[21/10] overflow-hidden mb-16 grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-1000">
							<img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
						</div>
						<div class="max-w-2xl mx-auto text-center">
							<p class="text-accent-gold text-[10px] font-bold uppercase tracking-[0.4em] mb-8">{post.data.date}</p>
							<h2 class="text-4xl md:text-6xl mb-12 tracking-tight leading-tight">
								<a href={`/nieuws/${post.id || post.slug}`} class="hover:text-accent-gold transition-colors">{post.data.title}</a>
							</h2>
							<p class="text-primary-text/60 text-lg mb-16 leading-relaxed italic font-light">
								"{post.body.substring(0, 180)}..."
							</p>
							<a href={`/nieuws/${post.id || post.slug}`} class="btn-theatre-outline">Lees bericht</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>
