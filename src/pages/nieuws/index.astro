---
import Layout from '../../layouts/Layout.astro';

const nieuws = Object.values(import.meta.glob('../../../content/nieuws/*.md', { eager: true }));
const sortedNieuws = nieuws.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date.split('-').reverse().join('-'));
  const dateB = new Date(b.frontmatter.date.split('-').reverse().join('-'));
  return dateB - dateA;
});
---

<Layout title="Nieuws">
	<section class="py-32 bg-primary-text text-bg-ivory">
		<div class="container-custom text-center">
			<h1 class="text-5xl md:text-8xl font-serif mb-8 tracking-tighter">Nieuws</h1>
			<p class="text-accent-gold uppercase tracking-[0.4em] text-xs font-bold">Het laatste uit onze coulissen</p>
		</div>
	</section>

	<section class="py-24">
		<div class="container-custom max-w-4xl">
			<div class="space-y-32">
				{sortedNieuws.map((post) => (
					<article class="group">
						<div class="aspect-[21/9] rounded-lg overflow-hidden border border-ui-border mb-12">
							<img src={post.frontmatter.image} alt={post.frontmatter.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" onerror="this.src='https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=1000&auto=format&fit=crop'" />
						</div>
						<div class="max-w-2xl">
							<p class="text-accent-gold text-xs font-bold uppercase tracking-[0.3em] mb-6">{post.frontmatter.date}</p>
							<h2 class="text-4xl md:text-5xl font-serif mb-8 hover:text-accent-burgundy transition-colors tracking-tight">
								<a href={`/nieuws/${post.file.split('/').pop().replace('.md', '')}`}>{post.frontmatter.title}</a>
							</h2>
							<p class="text-primary-text/70 text-lg mb-10 leading-relaxed">
								{post.rawContent().substring(0, 250)}...
							</p>
							<a href={`/nieuws/${post.file.split('/').pop().replace('.md', '')}`} class="btn-theatre-secondary">Lees volledig bericht</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>
